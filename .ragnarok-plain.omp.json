{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "cream": "#FEF5ED",
    "ember": "#EB516B",
    "ember_dark": "#2B0B0B",
    "forge": "#B83A48",
    "gold": "#F9C74F",
    "green": "#17D7A0",
    "mist": "#EBD6D6",
    "purple": "#8B5CF6",
    "slate": "#575656",
    "sky": "#7EB8DA"
  },
  "transient_prompt": {
    "template": "\ue285 ",
    "foreground": "p:ember",
    "background": "transparent"
  },
  "upgrade": {
    "source": "cdn",
    "interval": "168h",
    "auto": false,
    "notice": false
  },
  "console_title_template": "{{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "template": "{{ .Icon }}{{ if .WSL }} (WSL){{ end }} {{ .Shell }}",
          "foreground": "p:cream",
          "type": "os",
          "style": "plain"
        },
        {
          "template": " | ",
          "foreground": "p:slate",
          "type": "text",
          "style": "plain"
        },
        {
          "template": "\ueb99 {{ .UserName }} :: \uf108 {{ .HostName }}",
          "foreground": "p:forge",
          "type": "session",
          "style": "plain"
        },
        {
          "template": " | ",
          "foreground": "p:slate",
          "type": "text",
          "style": "plain"
        },
        {
          "options": {
            "time_format": "2006-01-02 15:04"
          },
          "template": "\uf073 {{ .CurrentDate | date .Format }}",
          "foreground": "p:purple",
          "type": "time",
          "style": "plain"
        },
        {
          "template": " | ",
          "foreground": "p:slate",
          "type": "text",
          "style": "plain"
        },
        {
          "template": "\ue266 RAM: {{ round .PhysicalPercentUsed .Precision }}% ({{ (div ((sub .PhysicalTotalMemory .PhysicalAvailableMemory)|float64) 1073741824.0) }}/{{ (div .PhysicalTotalMemory 1073741824.0) }}GB)",
          "foreground": "p:mist",
          "type": "sysinfo",
          "style": "plain"
        },
        {
          "template": " | ",
          "foreground": "p:slate",
          "type": "text",
          "style": "plain"
        },
        {
          "options": {
            "charged_icon": "\uf240 ",
            "charging_icon": "\ueb2d ",
            "discharging_icon": "\uf244 ",
            "not_charging_icon": "\uf241 "
          },
          "template": "{{ if not .Error }}{{ .Icon }} {{ .Percentage }} \uf295 <#575656>| </>{{ end }}{{ .Error }}",
          "foreground": "p:sky",
          "type": "battery",
          "style": "plain",
          "foreground_templates": [
            "{{ if eq \"Charging\" .State.String }}#17D7A0{{ end }}",
            "{{ if eq \"Discharging\" .State.String }}#7EB8DA{{ end }}",
            "{{ if eq \"Full\" .State.String }}#17D7A0{{ end }}"
          ]
        },
        {
          "options": {
            "style": "roundrock",
            "threshold": 0
          },
          "template": "\uf252 {{ .FormattedMs }} ",
          "foreground": "p:gold",
          "type": "executiontime",
          "style": "plain"
        }
      ],
      "newline": true
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "options": {
            "branch_icon": "\ue725 ",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{ if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "foreground": "p:green",
          "type": "git",
          "style": "plain",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#F9C74F{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#EB516B{{ end }}",
            "{{ if gt .Ahead 0 }}#17D7A0{{ end }}",
            "{{ if gt .Behind 0 }}#7EB8DA{{ end }}"
          ]
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "template": "\u256d\u2500",
          "foreground": "p:ember",
          "type": "text",
          "style": "plain"
        },
        {
          "template": "{{ if .Env.CONDA_DEFAULT_ENV }} \ued1b {{ .Env.CONDA_DEFAULT_ENV }} |{{ end }}",
          "foreground": "p:gold",
          "type": "text",
          "style": "plain"
        },
        {
          "options": {
            "folder_icon": "\uf07b ",
            "folder_separator_icon": " \uf061 ",
            "home_icon": "\ueb06 ",
            "style": "full"
          },
          "template": " {{ .Path }} ",
          "foreground": "p:sky",
          "type": "path",
          "style": "plain"
        }
      ],
      "newline": true
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "template": "\u2570\u2500 ",
          "foreground": "p:ember",
          "type": "text",
          "style": "plain"
        },
        {
          "options": {
            "always_enabled": true
          },
          "template": "{{ if gt .Code 0 }}<#EB516B>\uea87 {{ .Code }}</>{{ else }}<#17D7A0>\ueab2</>{{ end }} ",
          "type": "status",
          "style": "plain"
        }
      ],
      "newline": true
    }
  ],
  "version": 4,
  "final_space": true
}
